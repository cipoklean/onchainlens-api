# OnchainLens environment configuration (copy to .env — never commit .env)

# GoPlus Security API key (optional). Without it, unauthenticated rate limits apply.
# Get one at https://gopluslabs.io/ (developer dashboard).
GOPLUS_API_KEY=

# Protect your /audit endpoint. If set, callers MUST send:
#   Authorization: Bearer <this value>
# Leave empty for open (dev) mode.
API_BEARER_TOKEN=

# Comma-separated allowed CORS origins. Use "*" for fully public (no credentials).
# For production with a frontend, set e.g. https://app.example.com
CORS_ORIGINS=*

# Upstream response cache TTL in seconds (reduces GoPlus/RugCheck calls).
CACHE_TTL=120

# Max /audit requests per IP per 60s. Set 0 to disable.
RATE_LIMIT=60

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
